{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "include": ["ts/**/*.ts", "test/**/*.ts", "*.json"],
    "ignore": [
      "*.node",
      "node_modules",
      "target",
      "dist",
      "index.d.ts",
      "pnpm-lock.yaml"
    ]
  }
}
