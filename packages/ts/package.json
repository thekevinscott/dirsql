{
  "name": "dirsql",
  "version": "0.0.1",
  "description": "Ephemeral SQL index over a local directory",
  "license": "MIT",
  "repository": "https://github.com/thekevinscott/dirsql",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "dirsql": "dist/bin/dirsql.js"
  },
  "files": ["dist/", "dirsql.node", "README.md", "LICENSE"],
  "napi": {
    "binaryName": "dirsql",
    "triples": {}
  },
  "optionalDependencies": {
    "@dirsql/cli-linux-x64-gnu": "0.0.1",
    "@dirsql/cli-linux-arm64-gnu": "0.0.1",
    "@dirsql/cli-darwin-x64": "0.0.1",
    "@dirsql/cli-darwin-arm64": "0.0.1",
    "@dirsql/cli-win32-x64-msvc": "0.0.1"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "wireit",
    "build:debug": "wireit",
    "build:platforms": "tsx tools/buildPlatforms.ts",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "wireit",
    "test:unit": "wireit",
    "test:integration": "wireit",
    "coverage": "wireit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "wireit": {
    "napi:build": {
      "command": "napi build --release",
      "files": [
        "src/**/*.rs",
        "build.rs",
        "Cargo.toml",
        "../../packages/rust/src/**/*.rs",
        "../../packages/rust/Cargo.toml",
        "../../Cargo.toml"
      ],
      "output": ["dirsql.node", "ts/index.d.ts"]
    },
    "tsc": {
      "command": "tsc",
      "files": ["ts/**/*.ts", "tsconfig.json"],
      "output": ["dist/**"]
    },
    "build": {
      "dependencies": ["napi:build", "tsc"]
    },
    "build:debug": {
      "command": "napi build && tsc",
      "files": [
        "src/**/*.rs",
        "build.rs",
        "Cargo.toml",
        "../../packages/rust/src/**/*.rs",
        "ts/**/*.ts",
        "tsconfig.json"
      ],
      "output": ["dirsql.node", "dist/**", "ts/index.d.ts"]
    },
    "test": {
      "command": "vitest run",
      "dependencies": ["napi:build"],
      "files": ["ts/**/*.ts", "tools/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
      "output": []
    },
    "test:unit": {
      "command": "vitest run --dir src --passWithNoTests",
      "dependencies": ["napi:build"],
      "files": ["ts/**/*.ts", "src/**/*.ts", "vitest.config.ts"],
      "output": []
    },
    "test:integration": {
      "command": "vitest run --dir test --passWithNoTests",
      "dependencies": ["napi:build"],
      "files": ["ts/**/*.ts", "tools/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
      "output": []
    },
    "coverage": {
      "command": "vitest run --coverage",
      "dependencies": ["napi:build"],
      "files": ["ts/**/*.ts", "tools/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
      "output": ["coverage/**"]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@napi-rs/cli": "^3.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "wireit": "^0.14.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
