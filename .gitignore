/target
packages/*/target
.beads
.claude/settings.local.json
.claude/scheduled_tasks.lock
.worktrees/
notes/

# Generated by .claude/hooks/select-environment.sh on session start.
# The environment source files live in agents/environments/ and are checked in.
agents/build/

# Node
node_modules/
*.node

# TypeScript build output
packages/ts/dist/
# TypeScript coverage output
packages/ts/coverage/
# napi-rs generated type definitions (authored types live in packages/ts/ts/)
packages/ts/index.d.ts

# Python
__pycache__/
*.pyc
*.pyo
*.so
.venv/
.coverage
.pytest_cache/
# Rust CLI binary bundled into the wheel by CI (not in source control).
packages/python/python/dirsql/_binary/

# npm per-platform packages assembled from release archives
target/npm-platforms/

# wireit cache (per-package)
packages/*/.wireit/

# uv
uv.lock

# Dolt database files (added by bd init)
.dolt/
*.db

# VitePress / docs
docs/node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/

# Playwright
docs/test-results/
docs/playwright-report/
docs/blob-report/
docs/.playwright/
actionlint
